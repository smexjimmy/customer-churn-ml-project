# ============================================================
# Customer Churn MLOps — .gitignore
# Data files are tracked by DVC, NOT Git
# ============================================================

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual Environments ──────────────────────────────────
.env
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data (tracked by DVC, not Git) ───────────────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Models (tracked by DVC) ──────────────────────────────
models/*
!models/.gitkeep

# ── Metrics ──────────────────────────────────────────────
metrics/*
!metrics/.gitkeep

# ── MLflow ───────────────────────────────────────────────
mlruns/
mlflow/mlruns/

# ── DVC ──────────────────────────────────────────────────
.dvc/cache/
.dvc/tmp/

# ── Logs ─────────────────────────────────────────────────
logs/
*.log

# ── Secrets — NEVER commit these ─────────────────────────
.env
!.env.example

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Docker ───────────────────────────────────────────────
.docker/
