# Normalize line endings for cross-platform compatibility
* text=auto

# Python
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf

# Docker
Dockerfile text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files — no line-ending conversion
*.pkl binary
*.csv binary
*.png binary
*.jpg binary
